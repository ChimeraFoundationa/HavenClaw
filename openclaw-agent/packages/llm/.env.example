# OpenClaw Agent - LLM Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM Provider Selection
# ===========================================
# Options: openai, anthropic, google, local
LLM_PROVIDER=openai

# ===========================================
# OpenAI API Key (if using OpenAI)
# Get your key at: https://platform.openai.com/api-keys
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================
# Anthropic API Key (if using Anthropic)
# Get your key at: https://console.anthropic.com/settings/keys
# ===========================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ===========================================
# Google API Key (if using Google Gemini)
# Get your key at: https://makersuite.google.com/app/apikey
# ===========================================
GOOGLE_API_KEY=your-google-api-key-here

# ===========================================
# Optional: Custom Model Configuration
# ===========================================
# Override the default model for your provider
# LLM_MODEL=gpt-4o
# LLM_MODEL=claude-3-opus-20240229
# LLM_MODEL=gemini-1.5-pro

# ===========================================
# Optional: Local Model Configuration
# ===========================================
# For local models (Ollama, vLLM, etc.)
# LLM_PROVIDER=local
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama2

# ===========================================
# Optional: Advanced Settings
# ===========================================
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=2000

{
  "name": "havenclaw-agent",
  "version": "0.1.0",
  "private": true,
  "description": "HavenClaw Autonomous AI Agent for HAVEN Protocol",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "dev": "pnpm -r --parallel dev",
    "agent:start": "pnpm --filter agent-daemon start"
  },
  "keywords": [
    "ai-agent",
    "haven",
    "avalanche",
    "blockchain",
    "autonomous",
    "governance"
  ],
  "author": "HavenClaw Team",
  "license": "MIT",
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}

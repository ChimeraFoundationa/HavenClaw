# OpenClaw Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Network Configuration
# ===========================================
RPC_URL=http://localhost:8545
CHAIN_ID=31337

# ===========================================
# Operator Wallet (Agent Identity)
# ===========================================
OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ===========================================
# Contract Addresses (After Deployment)
# ===========================================
# ERC8004_REGISTRY=0x...
# AGENT_REGISTRY=0x...
# TASK_MARKETPLACE=0x...
# HAVEN_GOVERNANCE=0x...
# AGENT_REPUTATION=0x...
# PAYMENT_PROTOCOL=0x...

# ===========================================
# LLM Configuration (AI Provider)
# ===========================================
# Provider: openai, anthropic, google, or local
LLM_PROVIDER=openai

# OpenAI API Key (if using OpenAI)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (if using Anthropic)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google API Key (if using Google Gemini)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Custom model
# LLM_MODEL=gpt-4o
# LLM_MODEL=claude-3-opus-20240229
# LLM_MODEL=gemini-1.5-pro

# Optional: Local model (Ollama)
# LLM_PROVIDER=local
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama2

# ===========================================
# Agent Configuration
# ===========================================
AGENT_ID=my-agent
AGENT_NAME="My OpenClaw Agent"
AGENT_CAPABILITIES=trading,defi,governance,analysis

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

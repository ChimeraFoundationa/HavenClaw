# HavenClaw Environment Variables

# Private key for signing transactions
# Required for most operations
HAVENCLAW_PRIVATE_KEY=

# Custom RPC endpoint
# Default: https://api.avax-test.network/ext/bc/C/rpc (Fuji)
HAVENCLAW_RPC_URL=

# Network (fuji, mainnet, local)
# Default: fuji
HAVENCLAW_NETWORK=fuji

# Configuration file path
# Default: ~/.havenclaw/config.json
HAVENCLAW_CONFIG_PATH=

# Profile name for multi-profile setups
# Default: default
HAVENCLAW_PROFILE=

# Enable verbose logging
# Default: false
HAVENCLAW_VERBOSE=false

# Disable interactive prompts
# Default: false
HAVENCLAW_NO_PROMPT=false

# Skip onboarding wizard
# Default: false
HAVENCLAW_NO_ONBOARD=false

# Dashboard port
# Default: 18789
HAVENCLAW_DASHBOARD_PORT=18789

# IPFS endpoint for metadata storage
# Default: https://ipfs.infura.io:5001
HAVENCLAW_IPFS_URL=

# Enable debug mode
# Default: false
HAVENCLAW_DEBUG=false

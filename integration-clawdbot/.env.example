# Environment variables for Haven-Clawdbot Integration

# ============================================
# Blockchain Configuration
# ============================================

# Avalanche Fuji Testnet RPC
AVALANCHE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc

# Private key for the registrar wallet (DO NOT share!)
# This wallet will pay for gas fees to register agents
REGISTRAR_PRIVATE_KEY=your_registrar_wallet_private_key_here

# OneClickAgentRegistrar contract address (deploy first!)
ONE_CLICK_REGISTRAR_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# Clawdbot Configuration
# ============================================

# Your Clawdbot API Key
CLAWDBOT_API_KEY=your_clawdbot_api_key_here

# Clawdbot Analysis Endpoint
CLAWDBOT_ANALYZE_URL=https://api.clawdbot.ai/agent/analyze

# ============================================
# IPFS Configuration (Optional)
# ============================================

# Infura IPFS credentials (optional, falls back to data URI)
INFURA_PROJECT_ID=your_infura_project_id
INFURA_PROJECT_SECRET=your_infura_project_secret

# Or use custom IPFS node
# IPFS_HOST=ipfs.your-domain.com
# IPFS_PORT=5001

# ============================================
# Server Configuration
# ============================================

# Server port
PORT=3000

# Environment (development | production)
NODE_ENV=development

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# ============================================
# Security
# ============================================

# Rate limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Registration rate limit (per hour)
REGISTER_LIMIT_MAX=10

# ============================================
# Instructions
# ============================================
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to git
# 4. Keep PRIVATE_KEY secure!

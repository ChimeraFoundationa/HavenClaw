{
  "manifest_version": 3,
  "name": "Haven Framework for Clawdbot",
  "version": "1.0.0",
  "description": "Register your Clawdbot AI agents on Haven Framework - ERC-8004 Identity + ERC-6551 Token Bound Accounts",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://clowd.bot/*",
    "https://openclaw.ai/*",
    "https://*.clowd.bot/*",
    "https://*.openclaw.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://clowd.bot/*",
        "https://openclaw.ai/*",
        "https://*.clowd.bot/*",
        "https://*.openclaw.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Haven Framework"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://clowd.bot/*", "https://openclaw.ai/*"]
    }
  ]
}
